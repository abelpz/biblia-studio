{
  "name": "biblia-studio",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test --watch",
    "docs:api": "typedoc",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typedoc": "^0.28.18",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "lint-staged": {
    "*.{ts,tsx,md,json,yml,yaml}": "prettier --write"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
